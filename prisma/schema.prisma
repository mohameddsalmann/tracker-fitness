generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workouts Workout[]
  meals    Meal[]
  goals    Goal[]
  settings UserSettings?
}

model Workout {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  type      String
  duration  Int
  calories  Int
  notes     String?
  exercises Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Meal {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  slot      String
  name      String
  calories  Int
  protein   Float
  carbs     Float
  fat       Float
  quantity  Float    @default(1)
  unit      String   @default("serving")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Goal {
  id        String   @id @default(cuid())
  userId    String
  title     String
  type      String
  target    Float
  current   Float    @default(0)
  deadline  DateTime
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model UserSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  dietType      String   @default("none")
  allergens     String[] @default([])
  calorieTarget Int      @default(2000)
  notifyPush    Boolean  @default(true)
  notifyEmail   Boolean  @default(false)
  quietHoursOn  Boolean  @default(false)
  quietStart    String   @default("22:00")
  quietEnd      String   @default("07:00")
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
